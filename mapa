<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Mapa My Little Pony</title>

<style>

body{
  background:#f5f0ff;
  font-family:Arial;
  text-align:center;
}

/* MAPA */
.mapa{
  position:relative;
  width:90%;
  margin:auto;
}

.mapa img{
  width:100%;
  border-radius:15px;
}

/* PONTOS */
.ponto{
  position:absolute;
  width:14px;
  height:14px;
  border-radius:50%;
  cursor:pointer;
}

/* ANIMAÇÃO */
.desbloqueado{
  background:purple;
  animation:pulse 1.5s infinite;
}

@keyframes pulse{
  0%{box-shadow:0 0 0 0 rgba(128,0,128,0.7);}
  70%{box-shadow:0 0 0 12px rgba(128,0,128,0);}
  100%{box-shadow:0 0 0 0 rgba(128,0,128,0);}
}

/* BLOQUEADO */
.bloqueado{
  background:gray;
  opacity:0.5;
}

/* NOME AO PASSAR */
.ponto::after{
  content:attr(data-nome);
  position:absolute;
  top:-25px;
  left:-20px;
  background:black;
  color:white;
  padding:4px 6px;
  font-size:12px;
  border-radius:5px;
  display:none;
}

.ponto:hover::after{
  display:block;
}

/* CAIXA INFO */
.info{
  background:white;
  width:80%;
  margin:15px auto;
  padding:10px;
  border-radius:10px;
}

button{
  background:purple;
  color:white;
  border:none;
  padding:10px;
  border-radius:10px;
  margin-top:10px;
}

</style>
</head>

<body>

<h1>🗺️ Mapa de Equestria</h1>

<div class="mapa">

<img src="https://static.wikia.nocookie.net/mlp/images/a/a4/Map_of_Equestria_2015.jpg/revision/latest/scale-to-width-down/1000?cb=20240124202225">

<!-- PONYVILLE -->
<div class="ponto desbloqueado"
style="top:55%; left:45%;"
data-nome="Ponyville"
data-desc="Cidade principal onde vivem Twilight e seus amigos."
onclick="clicar(this)">
</div>

<!-- CANTERLOT -->
<div class="ponto desbloqueado"
style="top:48%; left:52%;"
data-nome="Canterlot"
data-desc="Capital de Equestria, lar da Princesa Celestia."
onclick="clicar(this)">
</div>

<!-- EVERFREE -->
<div class="ponto bloqueado"
style="top:58%; left:50%;"
data-nome="Everfree Forest"
data-desc="Floresta misteriosa e perigosa."
onclick="clicar(this)">
</div>

</div>

<!-- INFO -->
<div class="info">
<h2 id="nome"></h2>
<p id="desc"></p>

<button onclick="entrarLugar()">Entrar</button>
</div>

<script>

let lugarAtual = null;

function clicar(el){

  nome.innerText = el.dataset.nome;
  desc.innerText = el.dataset.desc;
  lugarAtual = el;

}

function entrarLugar(){

  if(!lugarAtual) return alert("Escolha um lugar!");

  if(lugarAtual.classList.contains("bloqueado")){
    alert("🔒 Lugar bloqueado!");
    return;
  }

  alert("✨ Entrando em " + lugarAtual.dataset.nome);

}

/* EXEMPLO DE DESBLOQUEIO AUTOMÁTICO */
setTimeout(()=>{
  let everfree = document.querySelector('[data-nome="Everfree Forest"]');
  everfree.classList.remove("bloqueado");
  everfree.classList.add("desbloqueado");
  alert("🌟 Novo lugar desbloqueado: Everfree Forest!");
},5000);

</script>

</body>
</html>
